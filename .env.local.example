# ============================================================
# 海问 HQ — 环境变量配置模板
# 将此文件复制为 .env.local 并填入真实值
# ============================================================

# Supabase — 在 https://supabase.com 项目设置 > API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key（用于服务端写入，在 Settings > API 中获取）
# 注意：此 Key 权限极高，不要暴露在前端，仅用于服务端
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# DeepSeek API — 在 https://platform.deepseek.com/api_keys 中获取
# 同时用于 Chat 和 Embedding
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Tavily Search API — 在 https://tavily.com 注册获取（免费层 1000次/月）
# 用于周更 Agent 联网搜索最新政策和新闻
TAVILY_API_KEY=tvly-your-tavily-api-key

# 周更 Agent 内部调用密钥（随机字符串，防止未授权触发）
CRON_SECRET=your-random-secret-string

# 应用 URL（本地开发用 localhost，部署后改为 Vercel 域名）
NEXT_PUBLIC_APP_URL=http://localhost:3000
