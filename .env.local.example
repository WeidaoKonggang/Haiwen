# ============================================================
# 海问 HQ — 环境变量配置模板
# 将此文件复制为 .env.local 并填入真实值
# ============================================================

# Supabase — 在 https://supabase.com 项目设置 > API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key（seed-rag.ts 写库需要，勿暴露前端）
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# DeepSeek API — 用于 Chat（流式对话）
# 在 https://platform.deepseek.com/api_keys 获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ────────── Embedding Provider ──────────
# 默认使用智谱 GLM（国内稳定，中文效果好）
# 可选值：zhipu / openai / siliconflow / deepseek
EMBEDDING_PROVIDER=zhipu
# 智谱可用模型：embedding-2（1024 维，默认）、embedding-3（2048 维）
EMBEDDING_MODEL=embedding-2

# 智谱 GLM API Key — 在 https://open.bigmodel.cn 注册获取
ZHIPU_API_KEY=your-zhipu-api-key

# 其他 provider（二选一即可）
# OPENAI_API_KEY=sk-your-openai-key
# SILICONFLOW_API_KEY=sk-your-siliconflow-key

# Tavily Search API — 周更 Agent 需要，在 https://tavily.com 免费注册
TAVILY_API_KEY=tvly-your-tavily-api-key

# Cron 内部调用密钥（随机字符串即可，防止未授权触发）
CRON_SECRET=your-random-secret-string

NEXT_PUBLIC_APP_URL=http://localhost:3000
